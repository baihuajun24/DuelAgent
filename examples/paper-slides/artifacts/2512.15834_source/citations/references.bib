	keywords = {Blue Gene systems, Cray XE system, Cray computers, Cray machines, Interference, Laser beams, Message passing, OS jitter, Resource management, Shape, Three-dimensional displays, Topology, allocation requests, batch jobs, communication performance, communication-heavy parallel application, compiler, computer center, energy cost saving, interference, network links, parallel processing, performance degradation, performance evaluation, performance variability, predictable performance, resource management, source code, system noise, system software changes, time estimation, torus networks},
	pages = {1--12},
}

@inproceedings{thiagarajan_paddle_2018,
	address = {Vancouver, BC},
	title = {{PADDLE}: {Performance} {Analysis} {Using} a {Data}-{Driven} {Learning} {Environment}},
	isbn = {978-1-5386-4368-6},
	shorttitle = {{PADDLE}},
	url = {https://ieeexplore.ieee.org/document/8425232/},
	doi = {10.1109/IPDPS.2018.00088},
	abstract = {The use of machine learning techniques to model execution time and power consumption, and, more generally, to characterize performance data is gaining traction in the HPC community. Although this signiﬁes huge potential for automating complex inference tasks, a typical analytics pipeline requires selecting and extensively tuning multiple components ranging from feature learning to statistical inferencing to visualization. Further, the algorithmic solutions often do not generalize between problems, thereby making it cumbersome to design and validate machine learning techniques in practice. In order to address these challenges, we propose a uniﬁed machine learning framework, PADDLE, which is speciﬁcally designed for problems encountered during analysis of HPC data. The proposed framework uses an information-theoretic approach for hierarchical feature learning and can produce highly robust and interpretable models. We present user-centric workﬂows for using PADDLE and demonstrate its effectiveness in different scenarios: (a) identifying causes of network congestion; (b) determining the best performing linear solver for sparse matrices; and (c) comparing performance characteristics of parent and proxy application pairs.},
	language = {en},
	urldate = {2020-06-11},
	booktitle = {2018 {IEEE} {International} {Parallel} and {Distributed} {Processing} {Symposium} ({IPDPS})},
	publisher = {IEEE},
	author = {Thiagarajan, Jayaraman J. and Anirudh, Rushil and Kailkhura, Bhavya and Jain, Nikhil and Islam, Tanzima and Bhatele, Abhinav and Yeom, Jae-Seung and Gamblin, Todd},
	month = may,
	year = {2018},
	pages = {784--793},
}

